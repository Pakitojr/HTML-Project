    <script>
      function mostrarSecao(secao) {
        // Esconder todas as seções
        const secoes = document.querySelectorAll('.secao');
        secoes.forEach(s => s.style.display = 'none');
        
        // Mostrar a seção selecionada
        document.getElementById(secao).style.display = 'block';
      }

    

      function mostrarCheat(cheat) {
        // Esconder todos os cheats
        const cheats = document.querySelectorAll('.cheat-item');
        cheats.forEach(c => c.style.display = 'none');
        
        // Mostrar o cheat selecionado
        document.getElementById(cheat).style.display = 'block';
      }

      function enviarComentario() {
        const nome = document.getElementById('nomeUsuario').value.trim();
        const texto = document.getElementById('textoComentario').value.trim();

        if (nome === '' || texto === '') {
          alert('Por favor, preencha nome e comentário!');
          return;
        }

        // Pegar comentários existentes do localStorage
        let comentarios = JSON.parse(localStorage.getItem('comentarios')) || [];

        // Adicionar novo comentário
        const novoComentario = {
          nome: nome,
          texto: texto,
          data: new Date().toLocaleString('pt-BR')
        };

        comentarios.unshift(novoComentario); // Adiciona no começo
        localStorage.setItem('comentarios', JSON.stringify(comentarios));

        // Limpar campos
        document.getElementById('nomeUsuario').value = '';
        document.getElementById('textoComentario').value = '';

        // Atualizar lista
        carregarComentarios();
      }

      function carregarComentarios() {
        const comentarios = JSON.parse(localStorage.getItem('comentarios')) || [];
        const lista = document.getElementById('listaComentarios');

        if (comentarios.length === 0) {
          lista.innerHTML = '<p style="color: #b500fd; text-align: center;">Nenhum comentário ainda. Seja o primeiro! 😊</p>';
          return;
        }

        lista.innerHTML = comentarios.map(com => `
          <div class="comentario-item">
            <div class="comentario-header">
              <strong style="color: #c08bf0;">${com.nome}</strong>
              <span class="comentario-data">${com.data}</span>
            </div>
            <p class="comentario-texto">${com.texto}</p>
          </div>
        `).join('');
      }

      // Carregar comentários ao abrir a página
      window.addEventListener('load', carregarComentarios);
    </script>
